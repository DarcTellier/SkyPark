; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

ControlsRemap/action_list=Array[StringName]([&"ui_up", &"ui_down", &"ui_left", &"ui_right", &"ui_accept", &"ui_cancel"])

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SkyPark Adventures"
run/main_scene="uid://cktjl7g16o17h"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://Assets/icon.svg"

[autoload]

QuitGame="*res://Globals/QuitGame.gd"
CurrentScene="*res://Globals/currentScene.gd"
TransEaseSelect="*res://Globals/Trans_Ease_select.gd"
DialogManager="*res://Globals/DialogManager.gd"
InteractionManager="*res://interactions/InteractionManager.tscn"
PauseScreen="*res://Globals/Pause_Screen.tscn"
GPipeNetwork="*res://Globals/GPipeNetwork.gd"
GDoorNetwork="*res://Globals/GDoorNetwork.gd"
ConfigFileHandler="*res://Globals/ConfigFileHandler.gd"
GPlayer="*res://Globals/GPlayer.gd"
WebRadioStreamHelper="*uid://beu0w0y1c825u"

[display]

window/size/mode=4
window/size/always_on_top=true
window/stretch/mode="viewport"
window/stretch/aspect="expand"
mouse_cursor/custom_image="uid://c37duk2hwtx1k"

[editor_plugins]

enabled=PackedStringArray("res://addons/kanban_tasks/plugin.cfg", "res://addons/webradio/plugin.cfg")

